; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Synapxion"
run/main_scene="uid://ueaad6xdssey"
config/use_custom_user_dir=true
config/custom_user_dir_name="Rudwolf/Synap"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/bg_color=Color(0.92156863, 0.92156863, 0.92156863, 1)
boot_splash/image="uid://bipvpv4oq8fre"
config/icon="uid://tlw45oh1tjl4"
config/windows_native_icon="res://resource/appIcon/appicon.ico"

[display]

window/size/viewport_width=800
window/size/viewport_height=600
window/size/always_on_top=true
window/size/transparent=true
window/size/sharp_corners=true
window/stretch/mode="viewport"
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="Synapxion App"

[editor_plugins]

enabled=PackedStringArray("res://addons/FreeControl/plugin.cfg", "res://addons/Godot-MToon-Shader/plugin.cfg", "res://addons/vrm/plugin.cfg")

