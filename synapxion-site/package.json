    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
